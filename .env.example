# ProofRent public configuration example.
# Copy to .env for local development. Do not commit real secrets.

# Frontend
VITE_PROOFRENT_API_URL=http://localhost:8787
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_PROOFRENT_PROGRAM_ID=
VITE_PROOFRENT_TRUSTED_ISSUER=

# Optional MagicBlock frontend configuration.
# Leave blank to run the honest local simulation path.
VITE_MAGICBLOCK_PER_RPC_URL=
VITE_MAGICBLOCK_ATTESTATION_URL=
VITE_MAGICBLOCK_ACCESS_TOKEN_URL=
VITE_MAGICBLOCK_EXECUTION_PUBLIC_KEY=

# Backend
PROOFRENT_CONFIDENTIAL_PORT=8787

# Optional stable issuer seed for repeatable local judging.
# Use a new random value for private demos. Never reuse in production.
PROOFRENT_SIGNING_SEED=
SERVER_PROOF_ISSUER_PUBLIC_KEY=

# Optional MagicBlock backend configuration.
# All three must be present for real MagicBlock PER execution mode.
MAGICBLOCK_PER_RPC_URL=
MAGICBLOCK_ATTESTATION_URL=
MAGICBLOCK_ACCESS_TOKEN_URL=
SOLANA_RPC_URL=https://api.devnet.solana.com
PROOFRENT_PROGRAM_ID=

# Optional Solana devnet commitment configuration.
# SERVER_SOLANA_PAYER_SECRET_KEY accepts a base58 secret key or JSON byte array.
# Never commit a funded or mainnet keypair.
SERVER_SOLANA_RPC_URL=https://api.devnet.solana.com
SERVER_PROOFRENT_PROGRAM_ID=
SERVER_SOLANA_PAYER_SECRET_KEY=
