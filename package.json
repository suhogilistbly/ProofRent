{
  "name": "proofrent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b && tsc -p tsconfig.server.json --noEmit",
    "server:build": "tsc -p tsconfig.server.json",
    "server:dev": "tsc -p tsconfig.server.json --watch --preserveWatchOutput",
    "server:start": "node dist-server/server/index.js",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "test": "npm run build && node --test dist-server/server/proofService.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "framer-motion": "12.38.0",
    "lucide-react": "1.14.0",
    "postcss": "8.5.14",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.0",
    "tailwindcss": "^3.4.17",
    "tweetnacl": "^1.0.3",
    "typescript": "6.0.3",
    "vite": "8.0.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
